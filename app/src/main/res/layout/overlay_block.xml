<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#E6000000"
    android:padding="24dp">

    <ImageView
        android:id="@+id/catImage"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:src="@drawable/ic_cat"
        android:contentDescription="cat" />

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="मैं आऊं मैं आऊं, तुम्हारा प्यारा 🐱"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center" />

    <TextView
        android:id="@+id/subText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="मत कर लाला, मत कर! यह गंदी चीज़ है।"
        android:textColor="#FFCDD2"
        android:textSize="18sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/streakText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textColor="#A5D6A7"
        android:textSize="16sp"
        android:gravity="center" />

    <Button
        android:id="@+id/closeButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="बंद करें (बस आवाज़ रोकें)"
        android:enabled="true" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="यह screen पूरी तरह सिर्फ phone restart करने पर हटेगी"
        android:textColor="#BDBDBD"
        android:textSize="12sp"
        android:gravity="center" />

</LinearLayout>
