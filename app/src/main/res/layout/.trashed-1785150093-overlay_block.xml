<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#EE1A1A1A"
    android:padding="24dp">

    <ImageView
        android:id="@+id/catImage"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_cat"
        android:contentDescription="cat" />

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Blocked Content Detected"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center" />

    <TextView
        android:id="@+id/subText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Stop. Close this and step away."
        android:textColor="#D0D0D0"
        android:textSize="16sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/streakText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textColor="#9DB4C7"
        android:textSize="14sp"
        android:gravity="center" />

    <Button
        android:id="@+id/closeButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:backgroundTint="#2C3E50"
        android:textColor="#FFFFFF"
        android:text="Mute Sound" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="This screen will only close after a phone restart."
        android:textColor="#9E9E9E"
        android:textSize="12sp"
        android:gravity="center" />

</LinearLayout>
