<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🐱 PhoneGuard"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/streakDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textSize="18sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Step 1: Accessibility permission दें (यह browser की website check करने के लिए ज़रूरी है)"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnAccessibility"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Accessibility Settings खोलें" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Step 2: Overlay permission दें (ताकि cat screen दिखा सके)"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Overlay Permission दें" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Blocked keywords / domains (एक लाइन में एक):"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/editKeywords"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:gravity="top"
        android:inputType="textMultiLine"
        android:background="#11000000"
        android:padding="8dp" />

    <Button
        android:id="@+id/btnSaveKeywords"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Save Keywords" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:textColor="#2E7D32"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnTestOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Test करें (Cat screen दिखाओ)" />

</LinearLayout>
</ScrollView>
